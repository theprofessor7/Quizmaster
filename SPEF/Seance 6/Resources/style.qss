/* ================= GLOBAL ================= */QWidget {    font-family: "Segoe UI", Arial;    font-size: 14px;}/* ================= START SCREEN ================= */#startScreen QLabel {    font-size: 36px;    font-weight: bold;    color: white;}#startScreen QPushButton {    background-color: rgba(59,130,246,0.9);    color: white;    border-radius: 15px;    padding: 14px 26px;    font-size: 18px;}#startScreen QPushButton:hover {    background-color: rgba(37,99,235,0.95);}/* ================= RESULT SCREEN ================= */#resultScreen QLabel {    font-size: 40px;    font-weight: bold;    color: white;}#resultScreen QPushButton {    background-color: rgba(16,185,129,0.9);    color: white;    border-radius: 15px;    padding: 14px 26px;    font-size: 18px;}#resultScreen QPushButton:hover {    background-color: rgba(5,150,105,0.95);}/* ================= QUIZ SCREEN ================= *//* ================= QUESTION ================= */#questionLabel {    font-size: 18px;    font-weight: bold;    color: white;    padding: 15px;}/* ================= SCORE ================= */#scoreLabel {    font-size: 18px;    font-weight: bold;    color: white;}/* ================= ANSWERS ================= */QRadioButton {    color: white;    font-size: 16px;    padding: 10px;    border-radius: 8px;}/* effet carte pour réponses */QRadioButton:hover {    background-color: rgba(0,0,0,0.4);}QRadioButton::indicator {    width: 18px;    height: 18px;}QRadioButton::indicator:unchecked {    border: 2px solid white;    border-radius: 9px;    background: transparent;}QRadioButton::indicator:checked {    border: 2px solid #3b82f6;    border-radius: 9px;    background-color: #3b82f6;}/* ================= BUTTONS ================= */QPushButton {    background-color: #3b82f6;    color: white;    border-radius: 10px;    padding: 10px 18px;    border: none;    font-weight: bold;}QPushButton:hover {    background-color: #2563eb;}QPushButton:pressed {    background-color: #1d4ed8;}QPushButton:disabled {    background-color: #94a3b8;    color: #e2e8f0;}/* ================= PROGRESS BAR ================= */QProgressBar {    border-radius: 10px;    text-align: center;    height: 20px;    background-color: rgba(255,255,255,0.3);    color: white;    font-weight: bold;}QProgressBar::chunk {    background-color: #3b82f6;    border-radius: 10px;}